<Prefab>
  <Window>
    <!--
      Planning Mode panel (read-only slice). A dark fixed panel centred at the
      top, clear of the left-side formation cards; left-aligned title + plan
      summary. Attributes all verified against shipped vanilla/BannerKings
      prefabs (Brush.FontSize, Brush.TextHorizontalAlignment, BlankWhiteSquare_9,
      #RRGGBBAA colour). Editing widgets replace the summary text next.
    -->
    <Widget DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
      <Children>
        <Widget WidthSizePolicy="Fixed" SuggestedWidth="900" HeightSizePolicy="Fixed" SuggestedHeight="450"
                HorizontalAlignment="Center" VerticalAlignment="Top" MarginTop="80"
                Sprite="BlankWhiteSquare_9" Color="#0A0D11F2">
          <Children>
            <TextWidget Text="@TitleText"
                        WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                        VerticalAlignment="Top" MarginTop="16" MarginLeft="28" MarginRight="28"
                        Brush="AgentHUD.Interaction.Text" Brush.FontSize="28" Brush.TextHorizontalAlignment="Left" />
            <TextWidget Text="@SummaryText"
                        WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                        VerticalAlignment="Top" MarginTop="66" MarginLeft="28" MarginRight="28"
                        Brush="AgentHUD.Interaction.Text" Brush.FontSize="19" Brush.TextHorizontalAlignment="Left" />
          </Children>
        </Widget>
      </Children>
    </Widget>
  </Window>
</Prefab>
