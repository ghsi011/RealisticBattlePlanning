<Prefab>
  <!--
    Planning Mode editor. A dark, framed panel centred at the top (clear of the
    left/right formation cards): an accented header bar, one card per live
    formation 1-8 ("N - composition" header; commanded cards show abort rule +
    "When -> Do" stage rows with - Stage / + Stage, uncommanded ones show a hint),
    a footer with player signals + live validation (errors red, warnings amber),
    and a bottom action bar (status line, Apply, Close). The layer takes input
    focus while open; buttons drive the VM, which mutates a PlanDraft and
    re-renders. Wording comes from Core's PlanFormatter.
  -->
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
      <Children>
        <Widget WidthSizePolicy="Fixed" SuggestedWidth="980" HeightSizePolicy="Fixed" SuggestedHeight="560"
                HorizontalAlignment="Center" VerticalAlignment="Top" MarginTop="64"
                Sprite="BlankWhiteSquare_9" Color="#14110CF7">
          <Children>

            <!-- Header bar -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="56"
                    VerticalAlignment="Top" Sprite="BlankWhiteSquare_9" Color="#241B10FF">
              <Children>
                <TextWidget Text="@TitleText" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            MarginLeft="26" MarginRight="220"
                            Brush="AgentHUD.Interaction.Text" Brush.FontSize="27" Brush.FontColor="#ECE2C8FF"
                            Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center" />
                <TextWidget Text="@HintText" WidthSizePolicy="Fixed" SuggestedWidth="200" HeightSizePolicy="StretchToParent"
                            HorizontalAlignment="Right" MarginRight="22"
                            Brush="AgentHUD.Interaction.Text" Brush.FontSize="15" Brush.FontColor="#9A9078FF"
                            Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center" />
              </Children>
            </Widget>
            <!-- Accent line under the header -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="2"
                    VerticalAlignment="Top" MarginTop="56" Sprite="BlankWhiteSquare_9" Color="#9A7B33FF" />

            <!-- Empty state (no formations yet) -->
            <TextWidget Text="@EmptyText" IsHidden="@HasPlan"
                        WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                        VerticalAlignment="Center" MarginLeft="40" MarginRight="40"
                        Brush="AgentHUD.Interaction.Text" Brush.FontSize="18" Brush.FontColor="#A89C80FF"
                        Brush.TextHorizontalAlignment="Center" />

            <!-- Body: one card per formation (scrolls when it overflows) -->
            <Widget IsVisible="@HasPlan" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                    MarginTop="68" MarginBottom="118" MarginLeft="24" MarginRight="16">
              <Children>
                <ScrollablePanel Id="ScrollPanel" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                 AutoHideScrollBars="true" ClipRect="ClipRect" InnerPanel="ClipRect\FormList"
                                 VerticalScrollbar="..\Scrollbar">
                  <Children>
                    <Widget Id="ClipRect" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                      <Children>
                        <ListPanel Id="FormList" DataSource="{Formations}"
                                   WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                   VerticalAlignment="Top" MarginRight="12" StackLayout.LayoutMethod="VerticalTopToBottom">
                          <ItemTemplate>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginBottom="14"
                                Sprite="BlankWhiteSquare_9" Color="#1E180FCC">
                          <Children>
                            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       MarginLeft="14" MarginRight="14" MarginTop="10" MarginBottom="12"
                                       StackLayout.LayoutMethod="VerticalTopToBottom">
                              <Children>
                                <!-- Formation header row: name (left) + stage controls (right) -->
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="30">
                                  <Children>
                                    <TextWidget Text="@NameText" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                MarginRight="180"
                                                Brush="AgentHUD.Interaction.Text" Brush.FontSize="21" Brush.FontColor="#E0B85EFF"
                                                Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center" />
                                    <ListPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                               WidthSizePolicy="CoverChildren" HeightSizePolicy="Fixed" SuggestedHeight="26"
                                               StackLayout.LayoutMethod="HorizontalLeftToRight">
                                      <Children>
                                        <ButtonWidget DoNotPassEventsToChildren="true" Command.Click="ExecuteRemoveStage" IsDisabled="@IsRemoveDisabled"
                                                      Brush="Rbp.Btn.Danger"
                                                      WidthSizePolicy="Fixed" SuggestedWidth="80" HeightSizePolicy="Fixed" SuggestedHeight="26">
                                          <Children>
                                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Text="- Stage"
                                                        Brush="AgentHUD.Interaction.Text" Brush.FontSize="13" Brush.FontColor="#E9CFC6FF"
                                                        Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" />
                                          </Children>
                                        </ButtonWidget>
                                        <ButtonWidget DoNotPassEventsToChildren="true" Command.Click="ExecuteAddStage" MarginLeft="8"
                                                      Brush="Rbp.Btn.Neutral"
                                                      WidthSizePolicy="Fixed" SuggestedWidth="80" HeightSizePolicy="Fixed" SuggestedHeight="26">
                                          <Children>
                                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Text="+ Stage"
                                                        Brush="AgentHUD.Interaction.Text" Brush.FontSize="13" Brush.FontColor="#D7E1EDFF"
                                                        Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" />
                                          </Children>
                                        </ButtonWidget>
                                      </Children>
                                    </ListPanel>
                                  </Children>
                                </Widget>
                                <!-- Abort rule (commanded) or an "uncommanded" hint (no stages) -->
                                <TextWidget Text="@AbortText" IsVisible="@HasStages" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="1"
                                            Brush="AgentHUD.Interaction.Text" Brush.FontSize="13" Brush.FontColor="#8C8470FF"
                                            Brush.TextHorizontalAlignment="Left" />
                                <TextWidget Text="@UncommandedText" IsVisible="@IsUncommanded" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="1"
                                            Brush="AgentHUD.Interaction.Text" Brush.FontSize="13" Brush.FontColor="#79767FCC"
                                            Brush.TextHorizontalAlignment="Left" />
                                <!-- Divider -->
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="1"
                                        MarginTop="6" MarginBottom="2" Sprite="BlankWhiteSquare_9" Color="#5A4A2A66" />
                                <!-- Stage rows -->
                                <ListPanel DataSource="{Stages}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                           StackLayout.LayoutMethod="VerticalTopToBottom">
                                  <ItemTemplate>
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="7">
                                      <Children>
                                        <TextWidget Text="@NumberText" WidthSizePolicy="Fixed" SuggestedWidth="26" HeightSizePolicy="CoverChildren"
                                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                                    Brush="AgentHUD.Interaction.Text" Brush.FontSize="18" Brush.FontColor="#D8A84CFF"
                                                    Brush.TextHorizontalAlignment="Left" />
                                        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="34"
                                                   StackLayout.LayoutMethod="VerticalTopToBottom">
                                          <Children>
                                            <!-- When: click to cycle the trigger type -->
                                            <ButtonWidget DoNotPassEventsToChildren="true" Command.Click="ExecuteCycleTrigger" Brush="Rbp.Field"
                                                          WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                                              <Children>
                                                <TextWidget Text="@TriggerText" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                            MarginLeft="6" MarginRight="6" MarginTop="2" MarginBottom="2"
                                                            Brush="AgentHUD.Interaction.Text" Brush.FontSize="16" Brush.FontColor="#93B0C4FF"
                                                            Brush.TextHorizontalAlignment="Left" />
                                              </Children>
                                            </ButtonWidget>
                                            <!-- Do: click to cycle the directive type -->
                                            <ButtonWidget DoNotPassEventsToChildren="true" Command.Click="ExecuteCycleDirective" Brush="Rbp.Field"
                                                          WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="3">
                                              <Children>
                                                <TextWidget Text="@DirectiveText" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                            MarginLeft="6" MarginRight="6" MarginTop="2" MarginBottom="2"
                                                            Brush="AgentHUD.Interaction.Text" Brush.FontSize="17" Brush.FontColor="#E2D2AEFF"
                                                            Brush.TextHorizontalAlignment="Left" />
                                              </Children>
                                            </ButtonWidget>
                                            <TextWidget Text="@EmitText" IsVisible="@HasEmit" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="2"
                                                        Brush="AgentHUD.Interaction.Text" Brush.FontSize="13" Brush.FontColor="#7E9A7EFF"
                                                        Brush.TextHorizontalAlignment="Left" />
                                          </Children>
                                        </ListPanel>
                                      </Children>
                                    </Widget>
                                  </ItemTemplate>
                                </ListPanel>
                              </Children>
                            </ListPanel>
                          </Children>
                        </Widget>
                          </ItemTemplate>
                        </ListPanel>
                      </Children>
                    </Widget>
                  </Children>
                </ScrollablePanel>
                <ScrollbarWidget Id="Scrollbar" WidthSizePolicy="Fixed" SuggestedWidth="5" HeightSizePolicy="StretchToParent"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 AlignmentAxis="Vertical" Handle="ScrollbarHandle" MaxValue="100" MinValue="0">
                  <Children>
                    <ImageWidget Id="ScrollbarHandle" WidthSizePolicy="Fixed" SuggestedWidth="5" HeightSizePolicy="Fixed" SuggestedHeight="12"
                                 HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="#9A7B33CC" />
                  </Children>
                </ScrollbarWidget>
              </Children>
            </Widget>

            <!-- Footer: signals + live validation (errors red, warnings amber) -->
            <Widget IsVisible="@HasPlan" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="56"
                    VerticalAlignment="Bottom" MarginLeft="26" MarginRight="26" MarginBottom="58">
              <Children>
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="2"
                        VerticalAlignment="Top" Sprite="BlankWhiteSquare_9" Color="#5A4A2A66" />
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                           VerticalAlignment="Top" MarginTop="8" StackLayout.LayoutMethod="VerticalTopToBottom">
                  <Children>
                    <TextWidget Text="@SignalsText" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                Brush="AgentHUD.Interaction.Text" Brush.FontSize="15" Brush.FontColor="#B0A684FF"
                                Brush.TextHorizontalAlignment="Left" />
                    <TextWidget Text="@ErrorsText" IsVisible="@HasErrors" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="3"
                                Brush="AgentHUD.Interaction.Text" Brush.FontSize="14" Brush.FontColor="#E2603CFF"
                                Brush.TextHorizontalAlignment="Left" />
                    <TextWidget Text="@WarningsText" IsVisible="@HasWarnings" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="3"
                                Brush="AgentHUD.Interaction.Text" Brush.FontSize="14" Brush.FontColor="#D9A441FF"
                                Brush.TextHorizontalAlignment="Left" />
                  </Children>
                </ListPanel>
              </Children>
            </Widget>

            <!-- Action bar: status (left) | Apply, Close (right) -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="42"
                    VerticalAlignment="Bottom" MarginLeft="26" MarginRight="26" MarginBottom="12">
              <Children>
                <TextWidget Text="@StatusText" IsVisible="@HasStatus" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            MarginLeft="4" MarginRight="252"
                            Brush="AgentHUD.Interaction.Text" Brush.FontSize="14" Brush.FontColor="#9FD6A0FF"
                            Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center" />

                <ListPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                           WidthSizePolicy="CoverChildren" HeightSizePolicy="Fixed" SuggestedHeight="38"
                           StackLayout.LayoutMethod="HorizontalLeftToRight">
                  <Children>
                    <ButtonWidget DoNotPassEventsToChildren="true" Command.Click="ExecuteApply"
                                  Brush="Rbp.Btn.Confirm"
                                  WidthSizePolicy="Fixed" SuggestedWidth="128" HeightSizePolicy="Fixed" SuggestedHeight="38">
                      <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Text="Apply Plan"
                                    Brush="AgentHUD.Interaction.Text" Brush.FontSize="17" Brush.FontColor="#ECF6DDFF"
                                    Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" />
                      </Children>
                    </ButtonWidget>
                    <ButtonWidget DoNotPassEventsToChildren="true" Command.Click="ExecuteClose" MarginLeft="10"
                                  Brush="Rbp.Btn.Danger"
                                  WidthSizePolicy="Fixed" SuggestedWidth="100" HeightSizePolicy="Fixed" SuggestedHeight="38">
                      <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Text="Close"
                                    Brush="AgentHUD.Interaction.Text" Brush.FontSize="17" Brush.FontColor="#E9CFC6FF"
                                    Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" />
                      </Children>
                    </ButtonWidget>
                  </Children>
                </ListPanel>
              </Children>
            </Widget>

          </Children>
        </Widget>
      </Children>
    </Widget>
  </Window>
</Prefab>
