<Brushes>
  <!--
    Flat, dark-themed button brushes for the Planning Mode editor. Each is a
    single solid layer (BlankWhiteSquare_9) tinted per state via ColorFactor, so
    buttons get clear hover/press/disabled feedback while matching the panel's
    dark palette. The brush also carries the label's font color/size/alignment,
    so a ButtonWidget can render its text directly (no child label widget).
  -->

  <!-- Neutral slate: secondary actions (Add Formation, + Stage). -->
  <Brush Name="Rbp.Btn.Neutral" FontColor="#D7E1EDFF" FontSize="16"
         TextHorizontalAlignment="Center" TextVerticalAlignment="Center" TransitionDuration="0.1">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#2C3543FF" />
    </Layers>
    <Styles>
      <Style Name="Default"><BrushLayer Name="Default" ColorFactor="1.0" /></Style>
      <Style Name="Hovered"><BrushLayer Name="Default" ColorFactor="1.45" /></Style>
      <Style Name="Pressed"><BrushLayer Name="Default" ColorFactor="0.7" /></Style>
      <Style Name="Disabled" FontColor="#74808CAA"><BrushLayer Name="Default" ColorFactor="0.4" /></Style>
    </Styles>
  </Brush>

  <!-- Confirm green: the primary commit (Apply Plan). -->
  <Brush Name="Rbp.Btn.Confirm" FontColor="#EDF6DDFF" FontSize="17"
         TextHorizontalAlignment="Center" TextVerticalAlignment="Center" TransitionDuration="0.1">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#3C5A33FF" />
    </Layers>
    <Styles>
      <Style Name="Default"><BrushLayer Name="Default" ColorFactor="1.0" /></Style>
      <Style Name="Hovered"><BrushLayer Name="Default" ColorFactor="1.45" /></Style>
      <Style Name="Pressed"><BrushLayer Name="Default" ColorFactor="0.7" /></Style>
      <Style Name="Disabled" FontColor="#A8B79EAA"><BrushLayer Name="Default" ColorFactor="0.4" /></Style>
    </Styles>
  </Brush>

  <!-- Modal backdrop behind the trigger/directive picker: a dark, clickable scrim
       (a plain ButtonWidget ignores Sprite+Color and renders white, so it needs a
       brush). No hover/press change — it just dims the panel and catches the
       click-to-cancel. -->
  <Brush Name="Rbp.Backdrop" TransitionDuration="0">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#0A0805C8" />
    </Layers>
    <Styles>
      <Style Name="Default"><BrushLayer Name="Default" ColorFactor="1.0" /></Style>
      <Style Name="Hovered"><BrushLayer Name="Default" ColorFactor="1.0" /></Style>
      <Style Name="Pressed"><BrushLayer Name="Default" ColorFactor="1.0" /></Style>
    </Styles>
  </Brush>

  <!-- Inline click-to-cycle field (a stage's When / Do line). A faint chip that
       brightens on hover so the player sees the line is editable; the label text
       color comes from the child TextWidget. -->
  <Brush Name="Rbp.Field" TransitionDuration="0.1">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#FFFFFF14" />
    </Layers>
    <Styles>
      <Style Name="Default"><BrushLayer Name="Default" ColorFactor="1.0" /></Style>
      <Style Name="Hovered"><BrushLayer Name="Default" ColorFactor="2.6" /></Style>
      <Style Name="Pressed"><BrushLayer Name="Default" ColorFactor="0.6" /></Style>
    </Styles>
  </Brush>

  <!-- The interactive battle-map canvas — a CK/Total-War parchment staff map. It is a
       ButtonWidget (renders white through Sprite+Color), so the background is built from
       brush layers: an opaque tan base (always shows, even if the texture sprite isn't
       mission-loaded) under a paper-grain texture. No hover/press change (it is a map). -->
  <Brush Name="Rbp.MapCanvas" TransitionDuration="0">
    <Layers>
      <BrushLayer Name="Base"  Sprite="BlankWhiteSquare_9" Color="#877340FF" />
      <BrushLayer Name="Paper" Sprite="paper_texture_tile" Color="#CBB37AFF" />
    </Layers>
    <Styles>
      <Style Name="Default">
        <BrushLayer Name="Base" ColorFactor="1.0" />
        <BrushLayer Name="Paper" ColorFactor="1.0" />
      </Style>
      <Style Name="Hovered">
        <BrushLayer Name="Base" ColorFactor="1.0" />
        <BrushLayer Name="Paper" ColorFactor="1.0" />
      </Style>
      <Style Name="Pressed">
        <BrushLayer Name="Base" ColorFactor="1.0" />
        <BrushLayer Name="Paper" ColorFactor="1.0" />
      </Style>
    </Styles>
  </Brush>

  <!-- Muted danger: dismissive / removing actions (Close, - Stage). -->
  <Brush Name="Rbp.Btn.Danger" FontColor="#E9CFC6FF" FontSize="16"
         TextHorizontalAlignment="Center" TextVerticalAlignment="Center" TransitionDuration="0.1">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#4A2F2AFF" />
    </Layers>
    <Styles>
      <Style Name="Default"><BrushLayer Name="Default" ColorFactor="1.0" /></Style>
      <Style Name="Hovered"><BrushLayer Name="Default" ColorFactor="1.45" /></Style>
      <Style Name="Pressed"><BrushLayer Name="Default" ColorFactor="0.7" /></Style>
      <Style Name="Disabled" FontColor="#9A8079AA"><BrushLayer Name="Default" ColorFactor="0.4" /></Style>
    </Styles>
  </Brush>
</Brushes>
