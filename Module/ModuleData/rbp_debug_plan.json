{
  // RealisticBattlePlanning debug plan (dev/test authoring path).
  // Loaded at the start of every field battle the player commands; this is
  // the I3 verify scenario: infantry walks a 3-waypoint path, holds in
  // shieldwall, then charges 30 s later — all without the player giving any
  // order. Edit this file in the deployed module to iterate without
  // rebuilding (a rebuild overwrites it with the repo copy).
  //
  // Anchors: "OwnStart"/"TeamCenter" bases are relative — forward/right in
  // meters along the team's initial attack direction — so this plan works on
  // any scene.

  "playerSignals": [ "hammer" ],

  "anchors": [
    { "id": "wp-1", "basis": "OwnStart", "forward": 30.0, "right": 0.0 },
    { "id": "wp-2", "basis": "OwnStart", "forward": 60.0, "right": 25.0 },
    { "id": "wp-3", "basis": "OwnStart", "forward": 90.0, "right": 0.0 }
  ],

  "formations": [
    {
      "formation": "Infantry",
      "stages": [
        {
          "name": "advance by waypoints",
          "do": { "type": "MoveTo", "path": [ "wp-1", "wp-2", "wp-3" ] }
        },
        {
          "name": "form the wall",
          "when": [ { "type": "PositionReached", "anchor": "wp-3", "toleranceMeters": 12 } ],
          "do": { "type": "Hold", "arrangement": "ShieldWall" },
          "emit": [ "wall-formed" ]
        },
        {
          "name": "charge",
          "when": [ { "type": "TimerElapsed", "seconds": 30 } ],
          "do": { "type": "Charge" }
        }
      ],
      "abort": { "casualtiesAbovePercent": 50 }
    },
    {
      "formation": "Ranged",
      "stages": [
        {
          "do": { "type": "Hold", "arrangement": "Loose" }
        }
      ]
    }
  ]
}
