{
  // RealisticBattlePlanning debug plan — PLAYTEST-FIX verification round.
  // Exercises the three behaviours fixed from the 8-formation playtest:
  //   * Cavalry: hold, then FlankArc (charge allowed) — must work AROUND to the
  //     enemy flank and CHARGE IN (not circle forever at standoff).
  //   * HorseArcher: Skirmish at a set standoff — kite-and-shoot.
  //   * LightCavalry: Screen the RANGED formation (a non-player target).
  // Infantry/Ranged anchor the line so there's something to flank around.
  //
  // Edit this file in the deployed module to iterate without rebuilding.

  "playerSignals": [ "charge" ],

  "anchors": [],

  "formations": [
    {
      "formation": "Infantry",
      "stages": [
        { "name": "hold the line", "do": { "type": "Hold", "arrangement": "ShieldWall" } }
      ],
      "abort": { "casualtiesAbovePercent": 70 }
    },
    {
      "formation": "Ranged",
      "stages": [
        { "name": "loose at will", "do": { "type": "Hold", "arrangement": "Loose", "fire": "Free" } }
      ]
    },
    {
      "formation": "HorseArcher",
      "stages": [
        { "name": "circle at 70 m", "do": { "type": "Skirmish", "target": "Nearest", "standoffMeters": 70.0, "circle": true } }
      ]
    },
    {
      "formation": "LightCavalry",
      "stages": [
        { "name": "screen the archers", "do": { "type": "Screen", "target": "Ranged", "gapMeters": 30.0 } }
      ]
    },
    {
      "formation": "Cavalry",
      "stages": [
        { "name": "wait for it", "do": { "type": "Hold", "arrangement": "Line" } },
        {
          "name": "flank left and charge",
          "when": [ { "type": "TimerElapsed", "seconds": 12 } ],
          "do": { "type": "FlankArc", "side": "Left", "standoffMeters": 50.0 }
        }
      ],
      "abort": { "casualtiesAbovePercent": 80 }
    }
  ]
}
