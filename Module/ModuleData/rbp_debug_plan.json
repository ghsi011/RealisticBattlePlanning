{
  // RealisticBattlePlanning debug plan — I7 + I8 verification round.
  // A player-CONDUCTED assault: both formations hold until YOU call the
  // moment, then act. This exercises the Signal Palette (I8) directly, and
  // the override/resume/abort surfaces (I7) work on either formation.
  //
  // SIGNAL PALETTE (I8):
  //   Numpad1 = "advance"  -> archers move up to the volley line
  //   Numpad2 = "charge"   -> infantry charge
  //   (or console: rbp.signal advance / rbp.signal charge)
  //
  // OVERRIDE / RESUME (I7): mid-battle, manually order Infantry somewhere.
  //   Its plan suspends (watch for the battle message + rbp.log line naming
  //   the captain). Bring it back with:  rbp.resume Infantry   (or all)
  //   rbp.plan_status shows each formation's mode (Active/Suspended/Aborted).
  //
  // ABORT (I7): get the Infantry captain killed (or console-kill them).
  //   The formation reverts to vanilla AI with a notification; the rest of
  //   the plan keeps running.
  //
  // Edit this file in the deployed module to iterate without rebuilding.

  "playerSignals": [ "advance", "charge" ],

  "anchors": [
    { "id": "volley-line", "basis": "OwnStart", "forward": 40.0, "right": 0.0 }
  ],

  "formations": [
    {
      "formation": "Infantry",
      "stages": [
        {
          "name": "hold until the call",
          "do": { "type": "Hold", "arrangement": "ShieldWall" }
        },
        {
          "name": "charge on signal",
          "when": [ { "type": "PlayerSignal", "signal": "charge" } ],
          "do": { "type": "Charge" }
        }
      ],
      "abort": { "casualtiesAbovePercent": 50 }
    },
    {
      "formation": "Ranged",
      "stages": [
        {
          "name": "hold loose",
          "do": { "type": "Hold", "arrangement": "Loose" }
        },
        {
          "name": "advance on signal",
          "when": [ { "type": "PlayerSignal", "signal": "advance" } ],
          "do": { "type": "MoveTo", "anchor": "volley-line" }
        }
      ]
    }
  ]
}
