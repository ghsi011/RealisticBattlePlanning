{
  // RealisticBattlePlanning debug plan — matched to THIS save's formation layout:
  //   formations 1-2 = Infantry, 3-4 = Ranged, 5-6 = Cavalry, 7-8 = Horse Archer.
  // The game files troops into the 8 engine slots by its own classification, so a
  // directive must go on the SLOT that actually holds the troops you mean — not on
  // the slot whose class name matches (see formation-slots-vs-composition).
  // Engine slot -> formation number:
  //   Infantry=1  Ranged=2  Cavalry=3  HorseArcher=4
  //   Skirmisher=5  HeavyInfantry=6  LightCavalry=7  HeavyCavalry=8
  // So here:
  //   Infantry slot (formation 1, infantry):           hold the line.
  //   Skirmisher + HeavyInfantry (formations 5-6, CAVALRY): flank and charge.
  //   LightCavalry + HeavyCavalry (formations 7-8, HORSE ARCHERS): circle at 70 m.

  "playerSignals": [ "charge" ],
  "anchors": [],

  "formations": [
    {
      "formation": "Infantry",
      "stages": [
        { "name": "hold the line", "do": { "type": "Hold", "arrangement": "ShieldWall" } }
      ],
      "abort": { "casualtiesAbovePercent": 70 }
    },
    {
      "formation": "Skirmisher",
      "stages": [
        { "name": "wait for it", "do": { "type": "Hold", "arrangement": "Line" } },
        {
          "name": "flank left and charge",
          "when": [ { "type": "TimerElapsed", "seconds": 12 } ],
          "do": { "type": "FlankArc", "side": "Left", "standoffMeters": 50.0 }
        }
      ],
      "abort": { "casualtiesAbovePercent": 80 }
    },
    {
      "formation": "HeavyInfantry",
      "stages": [
        { "name": "wait for it", "do": { "type": "Hold", "arrangement": "Line" } },
        {
          "name": "flank right and charge",
          "when": [ { "type": "TimerElapsed", "seconds": 12 } ],
          "do": { "type": "FlankArc", "side": "Right", "standoffMeters": 50.0 }
        }
      ],
      "abort": { "casualtiesAbovePercent": 80 }
    },
    {
      "formation": "LightCavalry",
      "stages": [
        { "name": "circle at 70 m", "do": { "type": "Skirmish", "target": "Nearest", "standoffMeters": 70.0, "circle": true } }
      ]
    },
    {
      "formation": "HeavyCavalry",
      "stages": [
        { "name": "circle at 70 m", "do": { "type": "Skirmish", "target": "Nearest", "standoffMeters": 70.0, "circle": true } }
      ]
    }
  ]
}
