{
  // RealisticBattlePlanning debug plan (dev/test authoring path).
  // I4 verify scenario — a proto-feigned-retreat using the new triggers:
  //   1. Infantry holds in shieldwall.
  //   2. When the enemy commits to an attack (sustained approach), infantry
  //      falls back 30 m and signals; archers follow the signal back.
  //   3. When the enemy closes within 40 m anyway, infantry counter-charges.
  // Watch Logs\rbp.log for when "EnemyCommits" fires vs. what the AI did —
  // that timing is the R3 tuning data.
  // Edit this file in the deployed module to iterate without rebuilding.

  "playerSignals": [ "hammer" ],

  "anchors": [
    { "id": "fallback", "basis": "OwnStart", "forward": -30.0, "right": 0.0 }
  ],

  "formations": [
    {
      "formation": "Infantry",
      "stages": [
        {
          "name": "hold the line",
          "do": { "type": "Hold", "arrangement": "ShieldWall" }
        },
        {
          "name": "give ground",
          "when": [ { "type": "EnemyCommits" } ],
          "do": { "type": "MoveTo", "anchor": "fallback" },
          "emit": [ "falling-back" ]
        },
        {
          "name": "counter-charge",
          "when": [ { "type": "EnemyWithinDistance", "meters": 40 } ],
          "do": { "type": "Charge" }
        }
      ],
      "abort": { "casualtiesAbovePercent": 50 }
    },
    {
      "formation": "Ranged",
      "stages": [
        {
          "do": { "type": "Hold", "arrangement": "Loose" }
        },
        {
          "name": "fall back with the line",
          "when": [ { "type": "SignalReceived", "signal": "falling-back" } ],
          "do": { "type": "MoveTo", "anchor": "fallback" }
        }
      ]
    }
  ]
}
