{
  // RealisticBattlePlanning debug plan — tuned to THIS save's actual troop layout
  // (the game sorted troops into slots that don't match the class names):
  //   formation 7 & 8 (LightCavalry / HeavyCavalry slots) hold the HORSE ARCHERS,
  //   formation 3 (Cavalry slot) holds the cavalry, 1 & 2 are infantry.
  // So directives are assigned to the slots that actually hold the right troops:
  //   - LightCavalry + HeavyCavalry (the horse archers): Skirmish, CIRCLING at 70 m.
  //   - Cavalry: hold, then FlankArc (charge allowed).
  //   - Infantry: hold the line.
  // (This is exactly why planning needs to be by numbered formation + composition,
  //  not by class name — see the composition labels in the rbp.plan editor.)

  "playerSignals": [ "charge" ],
  "anchors": [],

  "formations": [
    {
      "formation": "Infantry",
      "stages": [
        { "name": "hold the line", "do": { "type": "Hold", "arrangement": "ShieldWall" } }
      ],
      "abort": { "casualtiesAbovePercent": 70 }
    },
    {
      "formation": "Cavalry",
      "stages": [
        { "name": "wait for it", "do": { "type": "Hold", "arrangement": "Line" } },
        {
          "name": "flank left and charge",
          "when": [ { "type": "TimerElapsed", "seconds": 12 } ],
          "do": { "type": "FlankArc", "side": "Left", "standoffMeters": 50.0 }
        }
      ],
      "abort": { "casualtiesAbovePercent": 80 }
    },
    {
      "formation": "LightCavalry",
      "stages": [
        { "name": "circle at 70 m", "do": { "type": "Skirmish", "target": "Nearest", "standoffMeters": 70.0, "circle": true } }
      ]
    },
    {
      "formation": "HeavyCavalry",
      "stages": [
        { "name": "circle at 70 m", "do": { "type": "Skirmish", "target": "Nearest", "standoffMeters": 70.0, "circle": true } }
      ]
    }
  ]
}
